<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- ViewFlipper: 0=name input, 1=quiz -->
    <ViewFlipper
        android:id="@+id/viewFlipper"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Child 0: Name Input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="24dp"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/CardStyle"
                android:elevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/before_start"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/foreground"
                        android:gravity="center"
                        android:layout_marginBottom="20dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/participant_name"
                        android:textSize="14sp"
                        android:textColor="@color/foreground"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/etParticipantName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/enter_full_name"
                        android:textSize="16sp"
                        android:background="@drawable/bg_input"
                        android:inputType="textPersonName"
                        android:textColor="@color/foreground"
                        android:textColorHint="@color/muted_foreground"
                        android:layout_marginBottom="20dp"
                        android:importantForAutofill="no" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBeginExam"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="@string/start_test"
                        android:textSize="16sp"
                        android:textAllCaps="false"
                        android:background="@drawable/bg_gradient_primary"
                        android:textColor="@color/primary_foreground"
                        app:backgroundTint="@null"
                        xmlns:app="http://schemas.android.com/apk/res-auto" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Child 1: Quiz -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Sticky Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/card"
                android:elevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp">

                    <!-- Left: Title + progress text -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/online_test"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/foreground" />

                        <TextView
                            android:id="@+id/tvProgress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textColor="@color/muted_foreground" />
                    </LinearLayout>

                    <!-- Timer -->
                    <TextView
                        android:id="@+id/tvTimer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="60:00"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:background="@drawable/bg_timer_normal"
                        android:textColor="@color/foreground"
                        android:layout_marginEnd="8dp" />

                    <!-- Exit button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnExit"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="@string/exit"
                        android:textSize="13sp"
                        android:textAllCaps="false"
                        android:textColor="@color/destructive"
                        app:strokeColor="@color/destructive"
                        xmlns:app="http://schemas.android.com/apk/res-auto" />
                </LinearLayout>

                <!-- Progress bar -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/bg_progress_track" />
            </LinearLayout>

            <!-- Scrollable Quiz Content -->
            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:scrollbars="none"
                android:overScrollMode="never"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Question Card -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/CardStyle"
                        android:elevation="4dp"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <!-- Question header -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="16dp">

                                <TextView
                                    android:id="@+id/tvQuestionNumber"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/foreground" />

                                <TextView
                                    android:id="@+id/tvQuestionOf"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="13sp"
                                    android:textColor="@color/muted_foreground" />
                            </LinearLayout>

                            <!-- Question text -->
                            <TextView
                                android:id="@+id/tvQuestionText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="17sp"
                                android:textColor="@color/foreground"
                                android:layout_marginBottom="20dp"
                                android:lineSpacingMultiplier="1.3" />

                            <!-- Options container -->
                            <LinearLayout
                                android:id="@+id/optionsContainer"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Navigation Buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="20dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnPrevious"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:text="@string/previous"
                            android:textAllCaps="false"
                            android:layout_marginEnd="8dp"
                            xmlns:app="http://schemas.android.com/apk/res-auto" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNext"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:text="@string/next"
                            android:textAllCaps="false"
                            android:background="@drawable/bg_gradient_primary"
                            android:textColor="@color/primary_foreground"
                            app:backgroundTint="@null"
                            xmlns:app="http://schemas.android.com/apk/res-auto" />
                    </LinearLayout>

                    <!-- Quick Navigation -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/CardStyle"
                        android:elevation="4dp"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/quick_nav"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/foreground"
                                android:layout_marginBottom="12dp" />

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rvQuestionNav"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:scrollbars="none"
                                android:overScrollMode="never"
                                android:nestedScrollingEnabled="false" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </LinearLayout>
    </ViewFlipper>
</LinearLayout>
