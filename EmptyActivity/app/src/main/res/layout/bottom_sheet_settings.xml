<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/foreground"
        android:layout_marginBottom="24dp" />

    <!-- Dark Mode -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/dark_mode"
            android:textSize="16sp"
            android:textColor="@color/foreground" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchDarkMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border"
        android:layout_marginBottom="16dp" />

    <!-- Sound Effects -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/sound_effects"
            android:textSize="16sp"
            android:textColor="@color/foreground" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchSoundEffects"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border"
        android:layout_marginBottom="16dp" />

    <!-- Background Music -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/background_music"
            android:textSize="16sp"
            android:textColor="@color/foreground" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchBackgroundMusic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border"
        android:layout_marginBottom="20dp" />

    <!-- Social Links -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFacebook"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/follow_facebook"
        android:textAllCaps="false"
        android:layout_marginBottom="10dp"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnWhatsapp"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/follow_whatsapp"
        android:textAllCaps="false"
        android:layout_marginBottom="10dp"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnTiktok"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/follow_tiktok"
        android:textAllCaps="false"
        xmlns:app="http://schemas.android.com/apk/res-auto" />
</LinearLayout>
