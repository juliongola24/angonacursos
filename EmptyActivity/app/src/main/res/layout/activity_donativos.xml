<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:paddingVertical="8dp"
        android:background="@color/card"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:contentDescription="@string/back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/donations_title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/foreground"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Support Message Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/CardStyle"
                android:elevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/support_platform"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/foreground"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/support_text_1"
                        android:textSize="14sp"
                        android:textColor="@color/muted_foreground"
                        android:lineSpacingMultiplier="1.3"
                        android:gravity="center"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/support_text_2"
                        android:textSize="14sp"
                        android:textColor="@color/muted_foreground"
                        android:lineSpacingMultiplier="1.3"
                        android:gravity="center"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center"
                        android:background="@drawable/bg_card_elevated">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/min_donation"
                            android:textSize="12sp"
                            android:textColor="@color/muted_foreground" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/min_value"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/any_value_welcome"
                        android:textSize="13sp"
                        android:textColor="@color/muted_foreground"
                        android:layout_marginTop="12dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- How to contribute -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/how_to_contribute"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/foreground"
                android:layout_marginBottom="12dp" />

            <!-- PayPay Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/CardStyle"
                android:elevation="4dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PayPay"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/foreground"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Envie o seu donativo via carteira PayPay"
                        android:textSize="13sp"
                        android:textColor="@color/muted_foreground"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="923 456 789"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:textColor="@color/foreground"
                            android:background="@color/muted"
                            android:padding="10dp" />

                        <ImageButton
                            android:id="@+id/btnCopyPaypay"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@android:drawable/ic_menu_edit"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:scaleType="centerInside"
                            android:contentDescription="@string/copied" />
                    </LinearLayout>

                    <!-- Multicaixa Express info -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@color/muted"
                        android:padding="16dp"
                        android:layout_marginTop="12dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Também pode doar via Multicaixa Express para a carteira PayPay:"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/foreground"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="1. Abrir o Multicaixa Express\n2. Ir em Transferências/Pagamentos\n3. Escolher Pagamentos por Referência\n4. Preencher os campos:"
                            android:textSize="13sp"
                            android:textColor="@color/muted_foreground"
                            android:lineSpacingMultiplier="1.4"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Valor: Valor pretendido"
                            android:textSize="13sp"
                            android:textColor="@color/foreground"
                            android:layout_marginBottom="4dp"
                            android:paddingStart="16dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:layout_marginBottom="4dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Entidade: 10116"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/foreground" />
                            <ImageButton
                                android:id="@+id/btnCopyEntidade"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@android:drawable/ic_menu_edit"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:scaleType="centerInside"
                                android:contentDescription="@string/copied" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Referência: 943693959"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/foreground" />
                            <ImageButton
                                android:id="@+id/btnCopyReferencia"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@android:drawable/ic_menu_edit"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:scaleType="centerInside"
                                android:contentDescription="@string/copied" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- KWiK Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/CardStyle"
                android:elevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KWiK"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/foreground"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Transfira usando o IBAN da conta KWiK"
                        android:textSize="13sp"
                        android:textColor="@color/muted_foreground"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="AO06042000000000061156412"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:textColor="@color/foreground"
                            android:background="@color/muted"
                            android:padding="10dp" />

                        <ImageButton
                            android:id="@+id/btnCopyKwik"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@android:drawable/ic_menu_edit"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:scaleType="centerInside"
                            android:contentDescription="@string/copied" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Send Receipt -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/CardStyle"
                android:elevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/send_receipt"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/foreground"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/receipt_desc"
                        android:textSize="13sp"
                        android:textColor="@color/muted_foreground"
                        android:lineSpacingMultiplier="1.3"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="angonurse@gmail.com"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:textColor="@color/foreground"
                            android:background="@color/muted"
                            android:padding="10dp" />

                        <ImageButton
                            android:id="@+id/btnCopyEmail"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@android:drawable/ic_menu_edit"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:scaleType="centerInside"
                            android:contentDescription="@string/copied" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOpenEmail"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="@string/open_email"
                        android:textAllCaps="false"
                        xmlns:app="http://schemas.android.com/apk/res-auto" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Thank you -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/CardStyle"
                android:elevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/thank_you"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/foreground"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/thank_you_desc"
                        android:textSize="13sp"
                        android:textColor="@color/muted_foreground"
                        android:gravity="center" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
